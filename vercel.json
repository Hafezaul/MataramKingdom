{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/assets-kerajaan/(.*)", "dest": "/assets-kerajaan/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/pages/(.*)", "dest": "/pages/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/iklan/(.*)", "dest": "/iklan/$1" },
    { "src": "/(.*)\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
